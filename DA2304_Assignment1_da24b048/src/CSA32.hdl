FullAdder(a=ahigh[14], b=bhigh[14], c=chigh[14], sum=sumhigh[14], carry=carryhigh[14]);
FullAdder(a=ahigh[15], b=bhigh[15], c=chigh[15], sum=sumhigh[15], carry=carryhigh[15]);

}