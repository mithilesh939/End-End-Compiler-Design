FullAdder(a=alow[11], b=blow[11], c=clow[11], sum=sumlow[11], carry=carrylow[11]);
FullAdder(a=alow[12], b=blow[12], c=clow[12], sum=sumlow[12], carry=carrylow[12]);
FullAdder(a=alow[13], b=blow[13], c=clow[13], sum=sumlow[13], carry=carrylow[13]);
FullAdder(a=alow[14], b=blow[14], c=clow[14], sum=sumlow[14], carry=carrylow[14]);
FullAdder(a=alow[15], b=blow[15], c=clow[15], sum=sumlow[15], carry=carrylow[15]);

// ---- HIGH 16 BITS ----
FullAdder(a=ahigh[0], b=bhigh[0], c=chigh[0], sum=sumhigh[0], carry=carryhigh[0]);
FullAdder(a=ahigh[1], b=bhigh[1], c=chigh[1], sum=sumhigh[1], carry=carryhigh[1]);
FullAdder(a=ahigh[2], b=bhigh[2], c=chigh[2], sum=sumhigh[2], carry=carryhigh[2]);
FullAdder(a=ahigh[3], b=bhigh[3], c=chigh[3], sum=sumhigh[3], carry=carryhigh[3]);
FullAdder(a=ahigh[4], b=bhigh[4], c=chigh[4], sum=sumhigh[4], carry=carryhigh[4]);
FullAdder(a=ahigh[5], b=bhigh[5], c=chigh[5], sum=sumhigh[5], carry=carryhigh[5]);
FullAdder(a=ahigh[6], b=bhigh[6], c=chigh[6], sum=sumhigh[6], carry=carryhigh[6]);
FullAdder(a=ahigh[7], b=bhigh[7], c=chigh[7], sum=sumhigh[7], carry=carryhigh[7]);
FullAdder(a=ahigh[8], b=bhigh[8], c=chigh[8], sum=sumhigh[8], carry=carryhigh[8]);
FullAdder(a=ahigh[9], b=bhigh[9], c=chigh[9], sum=sumhigh[9], carry=carryhigh[9]);
FullAdder(a=ahigh[10], b=bhigh[10], c=chigh[10], sum=sumhigh[10], carry=carryhigh[10]);
