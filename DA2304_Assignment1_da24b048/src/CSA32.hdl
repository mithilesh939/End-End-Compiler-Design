CHIP CSA32 {

IN alow[16], ahigh[16],
   blow[16], bhigh[16],
   clow[16], chigh[16];
OUT sumlow[16], sumhigh[16],
    carrylow[16], carryhigh[16];

PARTS:

// ---- LOW 16 BITS ----
FullAdder(a=alow[0], b=blow[0], c=clow[0], sum=sumlow[0], carry=carrylow[0]);
FullAdder(a=alow[1], b=blow[1], c=clow[1], sum=sumlow[1], carry=carrylow[1]);
